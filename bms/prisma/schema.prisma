// Prisma schema for Bakery Management System (BMS)
// Database: MySQL | ORM: Prisma

generator client {
  provider = "prisma-client"
  output   = "../generated/client"
}

datasource db {
  provider = "mysql"
  // Connection URL is configured in prisma.config.ts (Prisma v7 requirement)
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  DISTRIBUTOR
}

// Simplified lifecycle: no DRAFT or CONFIRMED — order starts at READY_FOR_DISTRIBUTION
enum OrderStatus {
  ready_for_distribution // default when order is created
  out_for_delivery       // set automatically when RouteRun is created
  delivered              // set by distributor after delivery
  cancelled              // set by admin
}

// Extended payment methods including debt and settlement types
enum PaymentMethod {
  CASH          // cash received on delivery
  BANK_TRANSFER // bank wire transfer
  CREDIT        // debt — no amount received, added to shop balance
  INSTALLMENT   // partial payment toward old debt
  SETTLEMENT    // full settlement of accumulated balance
}

enum ShopType {
  RETAIL
  WHOLESALE
  CAFE
  RESTAURANT
  OTHER
}

enum ExpenseType {
  FUEL
  OTHER
}

// ─── Models ───────────────────────────────────────────────────────────────────

// System users: admins and distributors
model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(DISTRIBUTOR)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  createdOrders      Order[]                  @relation("OrderCreatedBy")
  distributedOrders  Order[]                  @relation("OrderDistributor")
  assignments        DistributionAssignment[] @relation("AssignedDistributor")
  assignedBy         DistributionAssignment[] @relation("AssignedBy")
  payments           Payment[]                @relation("PaymentCreatedBy")
  orderEvents        OrderEvent[]
  priceAuditLogs     ProductAuditLog[]
  routeRuns          RouteRun[]
  orderReturns       OrderReturn[]

  @@map("users")
}

// Client shops that receive deliveries
model Shop {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String?
  shopType  ShopType @default(RETAIL)
  address   String   @db.Text
  city      String   // city / district — required
  latitude  Float?
  longitude Float?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  orders   Order[]
  payments Payment[]

  @@map("shops")
}

// Bakery products with price tracking
model Product {
  id        String   @id @default(cuid())
  name      String
  sku       String?  @unique
  unit      String   @default("piece") // e.g. piece, kg, loaf
  unitPrice Decimal  @db.Decimal(10, 2)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  orderItems  OrderItem[]
  auditLogs   ProductAuditLog[]
  returns     OrderReturn[]

  @@map("products")
}

// Tracks every price change for a product
model ProductAuditLog {
  id        String   @id @default(cuid())
  productId String
  oldPrice  Decimal  @db.Decimal(10, 2)
  newPrice  Decimal  @db.Decimal(10, 2)
  changedBy String   // userId
  changedAt DateTime @default(now())
  note      String?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [changedBy], references: [id])

  @@map("product_audit_logs")
}

// A delivery order for a shop
model Order {
  id            String      @id @default(cuid())
  shopId        String
  deliveryDate  DateTime    @db.Date
  status        OrderStatus @default(ready_for_distribution)
  notes         String?     @db.Text
  createdById   String
  distributorId String?     // assigned driver — set at order creation
  routeRunId    String?     // filled automatically when RouteRun is created
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relations
  shop        Shop                    @relation(fields: [shopId], references: [id])
  createdBy   User                    @relation("OrderCreatedBy", fields: [createdById], references: [id])
  distributor User?                   @relation("OrderDistributor", fields: [distributorId], references: [id])
  routeRun    RouteRun?               @relation(fields: [routeRunId], references: [id])
  items       OrderItem[]
  events      OrderEvent[]
  assignment  DistributionAssignment?
  payments    Payment[]
  returns     OrderReturn[]

  @@index([shopId])
  @@index([distributorId])
  @@index([routeRunId])
  @@map("orders")
}

// Line items inside an order (price is snapshotted at order time)
model OrderItem {
  id                String  @id @default(cuid())
  orderId           String
  productId         String
  quantity          Int
  unitPriceSnapshot Decimal @db.Decimal(10, 2) // locked price at order creation
  subtotal          Decimal @db.Decimal(10, 2) // quantity * unitPriceSnapshot
  isGift            Boolean @default(false)    // gift items: counted in vehicle load, excluded from invoice value

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

// Audit trail for order state changes
model OrderEvent {
  id          String   @id @default(cuid())
  orderId     String
  actorId     String
  description String
  createdAt   DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  actor User  @relation(fields: [actorId], references: [id])

  @@map("order_events")
}

// Delivery vehicles
model Vehicle {
  id          String   @id @default(cuid())
  name        String
  plateNumber String   @unique
  capacity    String?  // free text e.g. "500 kg"
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  assignments DistributionAssignment[]
  routeRuns   RouteRun[]

  @@map("vehicles")
}

// Links an order to a distributor (and optionally a vehicle) — kept for compatibility
model DistributionAssignment {
  id            String   @id @default(cuid())
  orderId       String   @unique // one assignment per order
  distributorId String
  vehicleId     String?
  assignedById  String
  assignedAt    DateTime @default(now())
  notes         String?

  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  distributor User     @relation("AssignedDistributor", fields: [distributorId], references: [id])
  vehicle     Vehicle? @relation(fields: [vehicleId], references: [id])
  assignedBy  User     @relation("AssignedBy", fields: [assignedById], references: [id])

  @@map("distribution_assignments")
}

// Return record registered by distributor at the customer site
model OrderReturn {
  id          String   @id @default(cuid())
  orderId     String
  productId   String
  quantity    Int
  reason      String?
  createdById String   // distributor who registered the return
  createdAt   DateTime @default(now())

  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
  createdBy User    @relation(fields: [createdById], references: [id])

  @@map("order_returns")
}

// Daily route run — groups all orders for one distributor in one trip
model RouteRun {
  id              String   @id @default(cuid())
  date            DateTime @db.Date
  distributorId   String
  vehicleId       String?
  whiteBagsLoaded Int      @default(0) // white bags loaded at start
  brownBagsLoaded Int      @default(0) // brown bags loaded at start
  reserveBags     Int      @default(0) // extra reserve bags
  notes           String?  @db.Text
  createdAt       DateTime @default(now())

  distributor User           @relation(fields: [distributorId], references: [id])
  vehicle     Vehicle?       @relation(fields: [vehicleId], references: [id])
  orders      Order[]        // orders linked when route is created
  expenses    RouteExpense[]

  @@index([distributorId])
  @@index([date])
  @@map("route_runs")
}

// Expenses recorded per route (fuel, etc.)
model RouteExpense {
  id         String      @id @default(cuid())
  routeRunId String
  type       ExpenseType @default(FUEL)
  amount     Decimal     @db.Decimal(10, 2)
  note       String?
  createdAt  DateTime    @default(now())

  routeRun RouteRun @relation(fields: [routeRunId], references: [id])

  @@map("route_expenses")
}

// Payment records for orders or on-account for a shop
model Payment {
  id          String        @id @default(cuid())
  shopId      String
  orderId     String?       // optional: tied to a specific order
  amount      Decimal       @db.Decimal(10, 2)
  method      PaymentMethod @default(CASH)
  paymentDate DateTime      @db.Date
  reference   String?       // check number, bank reference, etc.
  notes       String?       @db.Text
  createdById String
  createdAt   DateTime      @default(now())

  shop      Shop   @relation(fields: [shopId], references: [id])
  order     Order? @relation(fields: [orderId], references: [id])
  createdBy User   @relation("PaymentCreatedBy", fields: [createdById], references: [id])

  @@index([shopId])
  @@map("payments")
}
